# ── Synthesis.trade API keys (https://synthesis.trade/dashboard) ──
PUBLIC_KEY_SYNTH=pk_your_public_key_here
SECRET_KEY_SYNTH=sk_your_secret_key_here
SOLANA_ADDRESS=your_solana_address_here
POLYGON_ADDRESS=your_polygon_address_here

# ── OpenAI (GPT-4o predictions) ──
OPENAI_API_KEY=sk-proj-your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# ── NVIDIA (container runtime / inference) ──
NVIDIA_KEY=your_nvidia_api_key_here

# ── Optional: Project-level API key for account management ──
# PROJECT_API_KEY=

# ── Trading configuration ──
SIMULATION_MODE=true
MAX_POSITION_USDC=1000.0
MAX_SINGLE_ORDER_USDC=100.0
MAX_DAILY_LOSS_USDC=200.0
MAX_OPEN_POSITIONS=20

# ── AI thresholds ──
CONFIDENCE_THRESHOLD=0.55

# ── Approval gate ──
REQUIRE_APPROVAL=true
APPROVAL_TTL_SECONDS=300

# ── Server ──
SERVER_HOST=127.0.0.1
SERVER_PORT=8420

# ── Audit / data ──
AUDIT_LOG_DIR=data
PREDICTION_LOG_DIR=data
